{
  "version": "0.1.0",
  "name": "vote_app",
  "instructions": [
    {
      "name": "initialize",
      "accounts": [
        {
          "name": "voter",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "voterAccount",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": []
    },
    {
      "name": "vote",
      "accounts": [
        {
          "name": "voter",
          "isMut": true,
          "isSigner": true
        },
        {
          "name": "voterAccount",
          "isMut": true,
          "isSigner": false
        },
        {
          "name": "systemProgram",
          "isMut": false,
          "isSigner": false
        }
      ],
      "args": [
        {
          "name": "candidateId",
          "type": "u8"
        }
      ]
    }
  ],
  "accounts": [
    {
      "name": "VoterAccount",
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "voter",
            "type": "publicKey"
          },
          {
            "name": "hasVoted",
            "type": "bool"
          },
          {
            "name": "candidateId",
            "type": "u8"
          },
          {
            "name": "bump",
            "type": "u8"
          }
        ]
      }
    }
  ],
  "errors": [
    {
      "code": 6000,
      "name": "AlreadyVoted",
      "msg": "You have already voted"
    },
    {
      "code": 6001,
      "name": "InvalidCandidate",
      "msg": "Invalid candidate ID"
    }
  ]
}